[init]
  defaultBranch = main

[user]
  name  = {{ .full_name }}
  email = {{ .email }}
  signingkey = {{ .chezmoi.homeDir }}/.ssh/keys/id_ed25519.pub

[gpg]
  format = ssh

[gpg "ssh"]
  allowedSignersFile = {{ .chezmoi.homeDir }}/.ssh/allowed_signers

[github]
user = {{ .github_user }}

[core]
  editor = {{ .editor }}
  pager = less -FMRiX

{{ if lookPath "sops" }}
[diff "sopsdiff"]
  textconv = sops --decrypt
{{ end -}}

[commit]
  gpgsign = true

[push]
  autoSetupRemote = true
  default = simple

[pull]
  rebase = true

[rebase]
  autoStash = true

[tag]
  gpgsign = true

[color]
  ui = auto

[alias]
  dag = log --graph --format='format:%C(yellow)%h%C(reset) %C(blue)%an <%ae>%C(reset) %C(magenta)%cr%C(reset)%C(auto)%d%C(reset)%n%s' --date-order

# incldue work config
[includeIf "hasconfig:remote.*.url:git@github.com:codarise/**"]
  path = ~/.config/git/config-work
